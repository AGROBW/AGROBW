# ========================================
# BWAGRO - Variáveis de Ambiente
# ========================================

# ----------------------------------------
# Supabase Configuration
# ----------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------------------
# Captcha Configuration (Admin Login)
# ----------------------------------------
# Opção 1: Cloudflare Turnstile (Recomendado - Grátis)
# Criar conta em: https://dash.cloudflare.com/
# Menu: Turnstile > Add Site > Copiar Site Key
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Opção 2: hCaptcha (Alternativo)
# Criar conta em: https://www.hcaptcha.com/
# Dashboard > New Site > Copiar Site Key
# VITE_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# ⚠️ Desenvolvimento: Se nenhuma chave for configurada, um mock será usado

# ----------------------------------------
# API Keys (Externas)
# ----------------------------------------
# Google Maps API (para geolocalização de anúncios)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Mercado Pago (para pagamentos)
VITE_MERCADOPAGO_PUBLIC_KEY=your-mercadopago-public-key

# ----------------------------------------
# Configurações de Ambiente
# ----------------------------------------
NODE_ENV=development
VITE_APP_VERSION=1.0.0

# ----------------------------------------
# Rate Limiting (Admin Login)
# ----------------------------------------
# Configurações de rate limiting são hardcoded no código,
# mas podem ser movidas para variáveis de ambiente:
# VITE_ADMIN_LOGIN_MAX_ATTEMPTS=5
# VITE_ADMIN_LOGIN_WINDOW_MS=900000  # 15 minutos
# VITE_ADMIN_LOGIN_BLOCK_DURATION_MS=1800000  # 30 minutos

# ----------------------------------------
# Configurações SMTP (se necessário no frontend)
# ----------------------------------------
# Geralmente configurado no backend, mas pode ser necessário
# para envio de e-mails transacionais via Supabase Edge Functions
# VITE_SMTP_HOST=smtp.gmail.com
# VITE_SMTP_PORT=587
# VITE_SMTP_USER=your-email@gmail.com
# VITE_SMTP_PASSWORD=your-app-password

# ----------------------------------------
# Feature Flags
# ----------------------------------------
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_MODE=false
VITE_ENABLE_MAINTENANCE_MODE=false

# ----------------------------------------
# URLs e Links
# ----------------------------------------
VITE_APP_URL=http://localhost:5173
VITE_API_URL=https://your-api.com
VITE_WHATSAPP_NUMBER=5500000000000
VITE_EMAIL_BACKEND_URL=http://localhost:4010
EMAIL_BACKEND_PORT=4010
EMAIL_BACKEND_SECRET=your-backend-secret-here
EMAIL_PROCESSOR_AUTO_START=false
EMAIL_PROCESSOR_INTERVAL_MS=60000

# ----------------------------------------
# Outras Integrações
# ----------------------------------------
# Google Analytics
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry (Error Tracking)
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# LogRocket (Session Replay)
# VITE_LOGROCKET_APP_ID=xxx/xxx
